# Copy this file to .env and fill in your email service details
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
CONTACT_RECIPIENT_EMAIL=your-email@example.com
# Optional sender address shown in the email "From" field
EMAIL_FROM=Saniya <your-email@example.com>
